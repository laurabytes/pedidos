datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Pedido {
  id        Int      @id @default(autoincrement())
  userId    Int
  status    String
  total     Float
  createdAt DateTime @default(now())

  itens PedidoItem[]
}

model PedidoItem {
  id         Int   @id @default(autoincrement())
  pedidoId   Int
  produtoId  Int
  quantidade Int
  preco      Float

  pedido Pedido @relation(fields: [pedidoId], references: [id])
}

model Endereco {
  id     Int @id @default(autoincrement())
  userId Int
  rua    String
  cidade String
  estado String
  cep    String
}